<header class="header header--transparent" id="site-header" role="banner">
  <div class="container">
    <div class="header__inner">

      {# Burger / mobile toggle #}
      <button class="header-burger" id="mobile-menu-toggle"
              aria-label="{{ 'accessibility.open_menu' | t }}"
              aria-expanded="false"
              aria-controls="mobile-menu">
        <span class="header-burger__line"></span>
        <span class="header-burger__line"></span>
        <span class="header-burger__line"></span>
      </button>

      {# Logo #}
      <a href="/" class="header-logo" aria-label="{{ store.name }}">
        {% if store.logo %}
          <img src="{{ store.logo }}" alt="{{ store.name }}" class="header-logo__img" width="44" height="44" loading="eager">
        {% endif %}
        <span class="header-logo__text">
          {{ store.name | split(' ') | first }}<span>{{ store.name | split(' ') | slice(1) | join(' ') }}</span>
        </span>
      </a>

      {# Desktop navigation #}
      <nav class="header-nav" role="navigation" aria-label="Main navigation">
        {% for category in categories | slice(0, 6) %}
        <div class="header-nav__item">
          <a href="{{ category.url }}" class="header-nav__link">
            {{ category.name }}
            {% if category.children | length > 0 %}
            <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M6 9l6 6 6-6"/></svg>
            {% endif %}
          </a>

          {% if category.children | length > 0 %}
          <div class="mega-menu" role="menu">
            <div class="mega-menu__grid">
              {% for child in category.children | slice(0,6) %}
              <a href="{{ child.url }}" class="mega-menu__category" role="menuitem">
                {% if child.image %}
                <img src="{{ child.image }}" alt="{{ child.name }}" class="mega-menu__category-img" loading="lazy">
                {% endif %}
                <div class="mega-menu__category-info">
                  <span class="mega-menu__category-name">{{ child.name }}</span>
                </div>
              </a>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </nav>

      {# Search bar (desktop) #}
      {% if settings.show_search %}
      <div class="header-search hide-mobile" role="search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="search"
               id="header-search-input"
               name="q"
               placeholder="{{ 'header.search_placeholder' | t }}"
               aria-label="{{ 'header.search_placeholder' | t }}"
               autocomplete="off">
      </div>
      {% endif %}

      {# Actions #}
      <div class="header-actions">
        {# Mobile search toggle #}
        {% if settings.show_search %}
        <button class="header-action hide-desktop" id="mobile-search-toggle" aria-label="{{ 'header.search_placeholder' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </button>
        {% endif %}

        {# Wishlist #}
        {% if settings.show_wishlist %}
        <a href="{{ routes.wishlist }}" class="header-action hide-mobile" aria-label="{{ 'header.wishlist' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          {% if wishlist_count > 0 %}
          <span class="header-action__badge" aria-label="{{ wishlist_count }} items">{{ wishlist_count }}</span>
          {% endif %}
        </a>
        {% endif %}

        {# Account #}
        <a href="{{ customer.is_logged_in ? routes.account : routes.login }}" class="header-action hide-mobile" aria-label="{{ 'header.account' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        </a>

        {# Cart #}
        <button class="header-action" id="cart-toggle-btn" aria-label="{{ 'header.cart' | t }}" aria-expanded="false" aria-controls="cart-drawer">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
          <span class="header-action__badge" id="cart-count" {% if cart.count == 0 %}style="display:none"{% endif %} aria-live="polite">
            {{ cart.count | default(0) }}
          </span>
        </button>
      </div>

    </div>
  </div>
</header>

{# Mobile search panel #}
<div class="mobile-search-panel" id="mobile-search-panel" hidden>
  <div class="container" style="padding-block: var(--space-3);">
    <div class="header-search" style="max-width: 100%;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="search" id="mobile-search-field" placeholder="{{ 'header.search_placeholder' | t }}" aria-label="{{ 'header.search_placeholder' | t }}" autofocus>
      <button id="mobile-search-close" aria-label="{{ 'general.close' | t }}">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
</div>
