<article class="product-card" data-product-id="{{ product.id }}" role="listitem">
  <div class="product-card__media">
    <a href="{{ product.url }}" tabindex="-1" aria-hidden="true">
      <img src="{{ product.thumbnail | default(product.images[0].url) }}"
           alt="{{ product.name }}"
           class="product-card__img"
           loading="lazy"
           width="400"
           height="400">
    </a>

    {# Badges #}
    <div class="product-card__badges" aria-label="Product badges">
      {% if force_badge is defined and force_badge %}
        <span class="badge badge--sale">{{ force_badge }}</span>
      {% elseif product.discount_percent > 0 %}
        <span class="badge badge--sale">-{{ product.discount_percent }}%</span>
      {% endif %}
      {% if product.is_new %}
        <span class="badge badge--new">{{ 'product.new_badge' | t }}</span>
      {% endif %}
      {% if product.is_best_seller %}
        <span class="badge badge--hot">{{ 'product.bestseller_badge' | t }}</span>
      {% endif %}
    </div>

    {# Quick action buttons #}
    <div class="product-card__actions" aria-label="Quick actions">
      <button class="product-card__action-btn"
              data-action="quick-view"
              data-product="{{ product.id }}"
              aria-label="{{ 'product.quick_view' | t }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
      </button>
      <button class="product-card__action-btn"
              data-action="wishlist"
              data-product="{{ product.id }}"
              aria-label="{{ 'product.wishlist_add' | t }}"
              aria-pressed="{{ product.in_wishlist ? 'true' : 'false' }}">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="{{ product.in_wishlist ? 'currentColor' : 'none' }}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </button>
    </div>

    {# Quick add to cart slideup #}
    {% if product.in_stock %}
    <button class="product-card__quick-cart"
            data-action="add-to-cart"
            data-product="{{ product.id }}"
            aria-label="{{ 'product.add_to_cart' | t }}: {{ product.name }}">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:inline;vertical-align:middle;margin-inline-end:6px;"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
      {{ 'product.add_to_cart' | t }}
    </button>
    {% else %}
    <div class="product-card__quick-cart" style="background: var(--color-text-muted); cursor: not-allowed;">
      {{ 'general.out_of_stock' | t }}
    </div>
    {% endif %}
  </div>

  <div class="product-card__body">
    {% if product.category %}
    <span class="product-card__category">{{ product.category.name }}</span>
    {% endif %}

    <a href="{{ product.url }}" class="product-card__name" aria-label="{{ product.name }}">{{ product.name }}</a>

    {% if product.rating > 0 %}
    <div class="product-card__rating" aria-label="{{ product.rating }} stars out of 5">
      <div class="stars">
        {% for s in 1..5 %}
        <svg class="{{ s <= product.rating ? '' : 'star--empty' }}" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
      </div>
      {% if product.reviews_count %}<span class="product-card__rating-count">({{ product.reviews_count }})</span>{% endif %}
    </div>
    {% endif %}

    <div class="product-card__price">
      <span class="product-card__price-current" aria-label="Current price">
        {{ product.price | money }}
      </span>
      {% if product.compare_at_price > product.price %}
      <span class="product-card__price-original" aria-label="Original price">
        {{ product.compare_at_price | money }}
      </span>
      {% endif %}
    </div>
  </div>
</article>
