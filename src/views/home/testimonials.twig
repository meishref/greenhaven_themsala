{% set sec = components.home_testimonials %}
<section class="section testimonials" id="testimonials" aria-labelledby="testimonials-title">
  <div class="container">
    <div class="section-header reveal">
      <div class="section-header__eyebrow">آراء العملاء</div>
      <h2 class="section-header__title" id="testimonials-title">{{ sec.title | default('ماذا يقول عملاؤنا') }}</h2>
      {% if sec.subtitle %}
      <p class="section-header__subtitle">{{ sec.subtitle }}</p>
      {% endif %}
    </div>

    <div class="testimonials-grid">
      {% for review in sec.reviews %}
      <article class="testimonial-card reveal delay-{{ loop.index * 100 }}">
        <div class="testimonial-card__stars stars" aria-label="{{ review.rating }} stars">
          {% for s in 1..5 %}
          <svg class="{{ s <= review.rating ? '' : 'star--empty' }}" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          {% endfor %}
        </div>
        <p class="testimonial-card__text">"{{ review.text }}"</p>
        <div class="testimonial-card__author">
          {% if review.avatar %}
          <img src="{{ review.avatar }}" alt="{{ review.name }}" class="testimonial-card__avatar" loading="lazy" width="48" height="48">
          {% else %}
          <div class="testimonial-card__avatar-placeholder">{{ review.name | first | upper }}</div>
          {% endif %}
          <div>
            <p class="testimonial-card__name">{{ review.name }}</p>
            {% if review.date %}<p class="testimonial-card__date">{{ review.date }}</p>{% endif %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>
