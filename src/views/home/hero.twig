{% set hero = components.home_hero %}
<section class="hero" id="hero" aria-label="Hero">

  {# Background Image #}
  {% if hero.hero_image %}
  <img src="{{ hero.hero_image }}"
       alt="{{ hero.heading }}"
       class="hero__bg"
       fetchpriority="high"
       decoding="async">
  {% endif %}

  {# Gradient overlay #}
  {% if hero.show_overlay != false %}
  <div class="hero__overlay"
       style="opacity: {{ (hero.overlay_opacity | default(50)) / 100 }};"></div>
  {% endif %}

  {# Floating leaves #}
  {% if hero.show_floating_leaves != false %}
  <div class="hero__leaves" aria-hidden="true">
    {# Leaf SVG repeated with different sizes / positions via CSS nth-child #}
    {% for i in 1..5 %}
    <svg class="hero__leaf" viewBox="0 0 100 120" xmlns="http://www.w3.org/2000/svg"
         style="
           {% if i == 1 %}top:10%;left:5%;width:80px;{% endif %}
           {% if i == 2 %}top:25%;right:8%;width:110px;{% endif %}
           {% if i == 3 %}bottom:20%;left:12%;width:60px;{% endif %}
           {% if i == 4 %}top:60%;right:15%;width:90px;{% endif %}
           {% if i == 5 %}bottom:30%;left:40%;width:50px;{% endif %}
         ">
      <path d="M50 5 C 80 5, 95 35, 90 60 C 85 85, 65 110, 50 115 C 35 110, 15 85, 10 60 C 5 35, 20 5, 50 5 Z"/>
      <line x1="50" y1="10" x2="50" y2="110" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
      <line x1="50" y1="35" x2="25" y2="55" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
      <line x1="50" y1="35" x2="75" y2="55" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
      <line x1="50" y1="60" x2="22" y2="75" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
      <line x1="50" y1="60" x2="78" y2="75" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
    </svg>
    {% endfor %}
  </div>
  {% endif %}

  {# Content #}
  <div class="hero__content">
    {% if hero.badge_text %}
    <div class="hero__badge animate-fade-in-down" role="text">
      🌿 {{ hero.badge_text }}
    </div>
    {% endif %}

    <h1 class="hero__title animate-fade-in-up delay-200">
      {{ hero.heading | default('ابدأ رحلتك مع الطبيعة') | raw }}
    </h1>

    {% if hero.subheading %}
    <p class="hero__subtitle animate-fade-in-up delay-400">
      {{ hero.subheading }}
    </p>
    {% endif %}

    <div class="hero__actions">
      {% if hero.cta_primary_text %}
      <a href="{{ hero.cta_primary_url | default('/shop') }}"
         class="btn btn--accent btn--lg animate-fade-in-up delay-500">
        {{ hero.cta_primary_text }}
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path d="{{ store.dir == 'rtl' ? 'M19 12H5M12 5l-7 7 7 7' : 'M5 12h14M12 5l7 7-7 7' }}"/>
        </svg>
      </a>
      {% endif %}
      {% if hero.cta_secondary_text %}
      <a href="{{ hero.cta_secondary_url | default('/categories') }}"
         class="btn btn--secondary btn--lg animate-fade-in-up delay-600">
        {{ hero.cta_secondary_text }}
      </a>
      {% endif %}
    </div>
  </div>

  {# Scroll indicator #}
  <div class="hero__scroll" aria-hidden="true">
    <span>{{ 'hero.scroll_down' | t }}</span>
    <div class="hero__scroll-dot"></div>
  </div>

</section>
