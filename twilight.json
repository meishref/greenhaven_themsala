{
  "name": {
    "ar": "جرين هيفن برو",
    "en": "Green Haven Pro"
  },
  "repository": "https://github.com/roony/greenhaven",
  "author_email": "hello@greenhaven.com",
  "support_url": "https://greenhaven.com",
  "features": [
    "mega-menu",
    "fonts",
    "color",
    "breadcrumb"
