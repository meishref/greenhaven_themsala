        {
          "id": "font_arabic",
          "type": "items",
          "label": "خط عربي",
          "default": "Cairo",
          "options": [
            {
              "value": "Cairo",
              "label": "Cairo"
            },
            {
              "value": "Tajawal",
              "label": "Tajawal"
            },
            {
              "value": "Almarai",
              "label": "Almarai"
            }
          ]
