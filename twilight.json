        {
          "id": "font_english",
          "type": "items",
          "label": "خط إنجليزي",
          "default": "Poppins",
          "options": [
            {
              "value": "Poppins",
              "label": "Poppins"
            },
            {
              "value": "Inter",
              "label": "Inter"
            },
            {
              "value": "Nunito",
              "label": "Nunito"
            }
          ]
        }
      ]
