          "label": "اللون الأساسي",
          "default": "#1a5c32",
          "format": "color"
        },
        {
          "id": "color_secondary",
          "type": "string",
          "label": "اللون الثانوي",
          "default": "#2ecc71",
          "format": "color"
        },
        {
          "id": "color_accent",
          "type": "string",
          "label": "لون التمييز",
          "default": "#d4a843",
          "format": "color"
        },
        {
          "id": "color_bg",
          "type": "string",
          "label": "لون الخلفية",
          "default": "#faf9f5",
          "format": "color"
        }
      ]
